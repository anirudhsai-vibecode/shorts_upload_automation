# OAuth app credentials (Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Drive folder that contains short videos
DRIVE_FOLDER_LINK=https://drive.google.com/drive/folders/<folder-id>

# Optional: channel timezone offset from UTC
CHANNEL_TZ_OFFSET_HOURS=0

# Optional temp download folder
WORKDIR=/tmp/shorts_uploads
